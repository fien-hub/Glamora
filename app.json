{
  "expo": {
    "name": "Glamora",
    "slug": "glamora-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.glamora.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find beauty professionals near you.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We use your location to keep provider availability and travel estimates accurate while using the app.",
        "NSLocationAlwaysUsageDescription": "We use your location to keep provider availability and travel estimates accurate while using the app.",
        "NSCameraUsageDescription": "We need access to your camera to upload photos to your profile.",
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to upload images.",
        "NSCalendarsUsageDescription": "We need access to your calendar to add booking reminders."
      },
      "buildNumber": "4"
    },
    "android": {
      "package": "com.fien.glamoraapp",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo/vector-icons/fonts/AntDesign.ttf",
            "./node_modules/@expo/vector-icons/fonts/Entypo.ttf",
            "./node_modules/@expo/vector-icons/fonts/EvilIcons.ttf",
            "./node_modules/@expo/vector-icons/fonts/Feather.ttf",
            "./node_modules/@expo/vector-icons/fonts/FontAwesome.ttf",
            "./node_modules/@expo/vector-icons/fonts/FontAwesome5_Regular.ttf",
            "./node_modules/@expo/vector-icons/fonts/FontAwesome5_Solid.ttf",
            "./node_modules/@expo/vector-icons/fonts/FontAwesome5_Brands.ttf",
            "./node_modules/@expo/vector-icons/fonts/Foundation.ttf",
            "./node_modules/@expo/vector-icons/fonts/Ionicons.ttf",
            "./node_modules/@expo/vector-icons/fonts/MaterialCommunityIcons.ttf",
            "./node_modules/@expo/vector-icons/fonts/MaterialIcons.ttf",
            "./node_modules/@expo/vector-icons/fonts/Octicons.ttf",
            "./node_modules/@expo/vector-icons/fonts/SimpleLineIcons.ttf",
            "./node_modules/@expo/vector-icons/fonts/Zocial.ttf"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Glamora to use your location to find beauty professionals near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Glamora to access your photos to upload images."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Glamora to access your calendar to add booking reminders."
        }
      ],
      [
        "expo-apple-authentication"
      ],
      [
        "@react-native-google-signin/google-signin"
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Glamora to use Face ID for secure authentication."
        }
      ],
      [
        "@sentry/react-native/expo"
      ]
    ],
    "scheme": "glamora",
    "extra": {
      "eas": {
        "projectId": "981368a6-0d58-422e-976b-8caf8e7e6683"
      }
    }
  }
}
