# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe Configuration
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000

# Environment
EXPO_PUBLIC_ENV=development

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a project
# 2. Enable Google Sign-In API
# 3. Create OAuth 2.0 credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id_here

# Apple Sign-In Configuration
# Apple Sign-In is automatically configured through your Apple Developer account
# No additional environment variables needed
# Make sure to:
# 1. Enable "Sign in with Apple" capability in your Apple Developer account
# 2. Configure your app's bundle identifier
# 3. Add the Sign in with Apple capability in Xcode

# Analytics Configuration
# Get your Mixpanel token from: https://mixpanel.com/
# 1. Create a Mixpanel account
# 2. Create a new project
# 3. Copy the project token from Project Settings
EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_project_token_here

# Sentry Configuration (Error Tracking)
# Get your Sentry DSN from: https://sentry.io/
# 1. Create a Sentry account
# 2. Create a new React Native project
# 3. Copy the DSN from Project Settings > Client Keys (DSN)
# Note: Only used in production/staging, not in development
EXPO_PUBLIC_SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/your_project_id

