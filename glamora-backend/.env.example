# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Stripe Configuration (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# RevenueCat Configuration
REVENUECAT_SECRET_API_KEY=sk_your_revenuecat_secret_api_key
REVENUECAT_REQUIRED_ENTITLEMENT=

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Internal Webhook Secret (used by Supabase DB triggers to call backend)
# Must match public.system_config key `internal_webhook_secret` in Supabase.
INTERNAL_WEBHOOK_SECRET=your-strong-random-secret-here
